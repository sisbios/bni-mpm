generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Multi-tenant hierarchy ───────────────────────────────────────────────────

model Region {
  id        String   @id @default(cuid())
  name      String   // e.g. "BNI South Kerala"
  slug      String   @unique // e.g. "bni-south"
  logoUrl   String?
  settings  String   @default("{}") // JSON
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chapters Chapter[]
}

model Chapter {
  id          String   @id @default(cuid())
  regionId    String
  name        String   // e.g. "Oscar"
  slug        String   @unique // e.g. "oscar"
  city            String?
  meetingDay      String?  // e.g. "Tuesday"
  meetingTime     String?  // e.g. "07:00"
  meetingLocation String?  // e.g. "The Leela Hotel, Banquet Hall"
  meetingFee      Float?   // member meeting fee in INR
  visitorFee      Float?   // visitor meeting fee in INR
  logoUrl         String?
  isActive        Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  region Region @relation(fields: [regionId], references: [id])

  @@index([regionId])
}

// ── Core models (all scoped by chapterId) ────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      String   @default("member") // president | admin | member
  business  String?
  category  String?
  avatar            String?
  professionalPhoto String?
  address           String?
  isActive  Boolean  @default(true)
  membershipValidTill DateTime?
  joinedAt  DateTime?

  // Multi-tenant fields
  chapterId   String?
  regionId    String?  // set only for regionAdmin / platform roles
  accessLevel String   @default("member") // platform | regionAdmin | superadmin | officer | member

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rsvps         EventRSVP[]
  tasks         WeeklyTask[]
  achievements  GreenAchievement[]
  contactSphere ContactSphere[]
  auditLogs     AuditLog[]
  meetingSlots  MeetingSlot[]
  palmsEntries  PalmsEntry[]
  memberPins    MemberPin[]
  visitors      Visitor[]   @relation("VisitorReferrer")
  businessGoals BusinessGoal[]

  @@index([chapterId])
}

model Event {
  id        String   @id @default(cuid())
  chapterId String?
  date      DateTime
  title     String
  subtitle  String?
  tags      String   @default("[]")
  colors    String   @default("[]")
  eventType String   @default("chapter") // chapter | regional | training | social | trip | international
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rsvps        EventRSVP[]
  meetingSlots MeetingSlot[]

  @@index([date])
  @@index([chapterId])
}

model EventRSVP {
  id        String   @id @default(cuid())
  chapterId String?
  userId    String
  eventId   String
  status    String   @default("pending") // pending | confirmed | declined | maybe
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
  @@index([chapterId])
}

model WeeklyTask {
  id          String   @id @default(cuid())
  chapterId   String?
  userId      String
  week        String
  taskType    String   @default("call")
  contactName String
  phone       String?
  status      String   @default("pending")
  notes       String?
  allocatedBy String?
  contactSphereId String?
  contributorId   String?
  contributorName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  contactSphereEntry ContactSphere? @relation(fields: [contactSphereId], references: [id], onDelete: SetNull)

  @@index([userId, week])
  @@index([chapterId])
}

model GreenAchievement {
  id          String   @id @default(cuid())
  chapterId   String?
  userId      String
  category    String
  description String?
  points      Int      @default(1)
  date        DateTime @default(now())
  verified    Boolean  @default(false)
  verifiedBy  String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([chapterId])
}

model BusinessGoal {
  id          String    @id @default(cuid())
  chapterId   String?
  userId      String
  type        String
  title       String
  description String?
  category    String    @default("other")
  status      String    @default("upcoming")
  targetDate  DateTime?
  achievedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([chapterId])
}

model ContactSphere {
  id           String   @id @default(cuid())
  chapterId    String?
  userId       String
  contactName  String
  phone        String?
  email        String?
  business     String?
  relationship String?
  category     String?
  address      String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  allocations WeeklyTask[]

  @@index([userId])
  @@index([chapterId])
}

model AuditLog {
  id        String   @id @default(cuid())
  chapterId String?
  userId    String
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([chapterId])
}

model ChapterSetting {
  id        String   @id @default(cuid())
  chapterId String?
  key       String
  value     String
  updatedAt DateTime @updatedAt

  // key is unique per chapter (not globally)
  @@unique([chapterId, key])
}

model ChapterRole {
  id          String   @id @default(cuid())
  chapterId   String?
  slug        String
  label       String
  color       String   @default("#9CA3AF")
  accessLevel String   @default("member")
  group       String   @default("member")
  sortOrder   Int      @default(99)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  // slug unique per chapter
  @@unique([chapterId, slug])
  @@index([chapterId])
}

model PalmsEntry {
  id          String   @id @default(cuid())
  chapterId   String?
  userId      String
  week        String
  weekDate    DateTime

  attended    Boolean  @default(false)
  substitute  Boolean  @default(false)
  late        Boolean  @default(false)
  medical     Boolean  @default(false)

  referrals    Int      @default(0)
  visitors     Int      @default(0)
  testimonials Int      @default(0)
  oneToOnes    Int      @default(0)
  ceus         Int      @default(0)
  tyfcbAmount  Float    @default(0)

  notes       String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, week])
  @@index([userId])
  @@index([week])
  @@index([chapterId])
}

model BniPin {
  id          String   @id @default(cuid())
  chapterId   String?  // null = system-wide pin available to all chapters
  slug        String
  label       String
  description String?
  icon        String   @default("🏅")
  color       String   @default("#C9A84C")
  isSystem    Boolean  @default(true)
  sortOrder   Int      @default(0)

  memberPins MemberPin[]

  // slug unique per chapter (null chapterId = global)
  @@unique([chapterId, slug])
  @@index([chapterId])
}

model MemberPin {
  id         String   @id @default(cuid())
  chapterId  String?
  userId     String
  pinId      String   // FK to BniPin.id (was pinSlug — updated for multi-tenant)
  awardedBy  String?
  awardedAt  DateTime @default(now())
  notes      String?

  user User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  pin  BniPin @relation(fields: [pinId], references: [id], onDelete: Cascade)

  @@unique([userId, pinId])
  @@index([userId])
  @@index([chapterId])
}

model Visitor {
  id           String   @id @default(cuid())
  chapterId    String?
  name         String
  phone        String?
  email        String?
  business     String?
  category     String?

  referrerId   String
  visitDate    DateTime
  week         String
  weekDate     DateTime

  eoiSubmitted Boolean  @default(false)
  eoiDate      DateTime?

  fromContactId String?
  notes        String?
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  referrer User @relation("VisitorReferrer", fields: [referrerId], references: [id])

  @@index([referrerId])
  @@index([week])
  @@index([chapterId])
}

model MeetingSlot {
  id               String   @id @default(cuid())
  chapterId        String?
  eventId          String
  slotType         String
  slotNumber       Int      @default(1)
  assignedUserId   String?
  assignedUserName String?
  topic            String?
  status           String   @default("pending")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  event        Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  assignedUser User? @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([assignedUserId])
  @@index([chapterId])
}
